# Server
PORT=3000
NODE_ENV=development

# Database (MySQL / MariaDB)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=kafe_lumiere
DB_USER=kafe
DB_PASS=kafe_pass123

# Auth
JWT_SECRET=change_this_to_a_long_random_secret
